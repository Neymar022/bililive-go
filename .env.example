# Playwright E2E 测试环境变量配置
# 将此文件复制为 .env.local 并根据需要修改

# 本地 osrp-stream-tester 路径（可选）
# 如果设置，将使用本地目录而不是从远程拉取
# OSRP_STREAM_TESTER_PATH=C:/path/to/osrp-stream-tester

# ==== Bililive-Go 主程序环境变量 ====
# bgo 主程序也会读取 .env.local 文件

# 版本检测 API 地址（用于测试自动升级功能）
# 可设置为本地 HTTP 服务器地址，例如：
# VERSION_API_URL=http://localhost:8888/api/v1/version
# VERSION_API_URL=http://localhost:8888

# Sentry DSN（可选，用于错误监控）
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ==== 字幕增强环境变量 ====
# 阿里百炼 DashScope API Key（云端 Qwen ASR）
# DASHSCOPE_API_KEY=sk-xxxx

# DashScope 基础地址。兼容填写：
# https://dashscope.aliyuncs.com
# https://dashscope.aliyuncs.com/compatible-mode/v1
# worker 会自动归一化到正确根地址。
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI API Key（预留扩展位，首版非默认）
# OPENAI_API_KEY=sk-xxxx

# 容器网络代理（可选）
# 如果 NAS 可通过本地代理访问外网，可同时设置：
# HTTP_PROXY=http://192.168.1.80:20171
# HTTPS_PROXY=http://192.168.1.80:20171
# ALL_PROXY=socks5://192.168.1.80:20171

# Hugging Face 镜像地址（可选）
# 本地 faster-whisper 首次下载模型时可配合代理或镜像站使用
# HF_ENDPOINT=https://hf-mirror.com

# 对外可访问的 bililive-go /files 根地址。
# DashScope 文件转写模式要求它能直接访问 source 中抽出的音频文件。
# 默认 Docker 配置会把字幕渲染 preset 设为 vizard_classic_cn。
# SUBTITLE_PUBLIC_URL_BASE=https://your-bililive.example.com
